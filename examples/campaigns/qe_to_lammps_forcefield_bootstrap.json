{
  "name": "qe-to-lammps-forcefield-bootstrap",
  "description": "Electronic-structure-informed atomistic workflow for bootstrapping downstream LAMMPS conditions from Quantum ESPRESSO outputs.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "minimize_potential_energy",
      "metric_key": "potential_energy",
      "direction": "minimize",
      "weight": 1.0
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "ecutwfc", "kind": "continuous", "lower": 20.0, "upper": 90.0, "choices": [] },
      {
        "name": "lattice_parameter",
        "kind": "continuous",
        "lower": 8.0,
        "upper": 12.0,
        "choices": []
      }
    ]
  },
  "budget": {
    "max_runs": 4,
    "batch_size": 1,
    "max_failures": 2
  },
  "simulator": "quantum_espresso",
  "workflow": {
    "name": "qe-to-lammps-bootstrap",
    "stages": [
      {
        "name": "qe",
        "simulator": "quantum_espresso",
        "task": {
          "name": "qe_scf",
          "simulator": "quantum_espresso",
          "parameters": { "ecutwfc": 35.0, "conv_thr": 1e-6, "lattice_parameter": 10.2 },
          "units": { "ecutwfc": "Ry", "lattice_parameter": "bohr" },
          "expected_outputs": ["qe.in", "stdout.log", "stderr.log"],
          "metadata": {}
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      },
      {
        "name": "lammps",
        "simulator": "lammps",
        "task": {
          "name": "lammps_md",
          "simulator": "lammps",
          "parameters": {
            "steps": 25,
            "ensemble": "nvt",
            "thermo_frequency": 5,
            "timestep": 0.002
          },
          "units": { "timestep": "tau" },
          "expected_outputs": ["log.lammps", "stdout.log", "stderr.log"],
          "metadata": {
            "goal": "Carry electronic-structure information into a downstream atomistic screening stage."
          }
        },
        "depends_on": ["qe"],
        "mapping_id": "quantum_espresso_to_lammps",
        "metadata": {}
      }
    ],
    "metadata": {
      "story": "Use an upstream electronic-structure stage to bootstrap downstream atomistic simulation settings."
    }
  },
  "seed": 27,
  "tags": ["workflow", "quantum-espresso", "lammps", "multiscale", "forcefield-bootstrap"],
  "metadata": {
    "operator_prompt": "Run QE first, map its outputs into LAMMPS inputs, and keep the parameter transfer auditable in stage provenance.",
    "analysis_focus": "electronic-to-atomistic transfer traceability"
  }
}
