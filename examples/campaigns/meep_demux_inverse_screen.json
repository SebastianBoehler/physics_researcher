{
  "name": "meep-demux-inverse-screen",
  "description": "Two-port photonic demultiplexer screen with low-band to upper-port and high-band to lower-port routing.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_device_score",
      "metric_key": "device_score",
      "direction": "maximize",
      "weight": 1.0
    },
    {
      "name": "maximize_demux_score",
      "metric_key": "demux_score",
      "direction": "maximize",
      "weight": 0.5
    },
    {
      "name": "maximize_demux_target_mean",
      "metric_key": "demux_target_mean",
      "direction": "maximize",
      "weight": 0.25
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "block_x", "kind": "continuous", "lower": 2.2, "upper": 5.4, "choices": [] },
      { "name": "block_y", "kind": "continuous", "lower": 3.5, "upper": 7.0, "choices": [] },
      {
        "name": "refractive_index",
        "kind": "continuous",
        "lower": 2.4,
        "upper": 4.0,
        "choices": []
      },
      { "name": "arm_separation", "kind": "continuous", "lower": 2.4, "upper": 4.6, "choices": [] },
      { "name": "output_width", "kind": "continuous", "lower": 0.6, "upper": 1.3, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 8,
    "batch_size": 1,
    "max_failures": 3
  },
  "simulator": "meep",
  "workflow": {
    "name": "meep-demux-inverse-screen",
    "stages": [
      {
        "name": "meep",
        "simulator": "meep",
        "task": {
          "name": "meep_flux_scan",
          "simulator": "meep",
          "parameters": {
            "device_kind": "demux",
            "sx": 20.0,
            "sy": 10.0,
            "block_x": 3.4,
            "block_y": 5.0,
            "refractive_index": 3.3,
            "input_width": 1.0,
            "output_width": 0.9,
            "arm_separation": 3.2,
            "input_length": 5.0,
            "output_length": 5.0,
            "route_low_port": "upper",
            "route_high_port": "lower",
            "resolution": 18,
            "dpml": 1.0,
            "fcen": 0.16,
            "df": 0.12,
            "nfreq": 41,
            "until": 80
          },
          "units": {
            "sx": "um",
            "sy": "um",
            "block_x": "um",
            "block_y": "um",
            "arm_separation": "um",
            "output_width": "um"
          },
          "expected_outputs": ["meep_results.json", "stdout.log", "stderr.log"]
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      }
    ],
    "metadata": {
      "benchmark_family": "meep_photonic_devices",
      "device_class": "demux"
    }
  },
  "seed": 227,
  "tags": ["meep", "photonics", "inverse-design", "demux"],
  "metadata": {
    "operator_prompt": "Optimize a two-port spectral router with low-band energy routed upward and high-band energy routed downward.",
    "analysis_focus": "spectral routing contrast"
  }
}
