{
  "name": "longer-horizon-exploration",
  "description": "Moderate-budget campaign for watching optimizer behavior over several update cycles.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_conductivity",
      "metric_key": "conductivity",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [
    {
      "name": "cost_threshold",
      "metric_key": "cost",
      "operator": "lt",
      "threshold": 58.0
    },
    {
      "name": "stability_threshold",
      "metric_key": "stability",
      "operator": "gt",
      "threshold": 0.7
    }
  ],
  "search_space": {
    "dimensions": [
      { "name": "dopant_ratio", "kind": "continuous", "lower": 0.05, "upper": 0.5, "choices": [] },
      {
        "name": "anneal_temperature",
        "kind": "continuous",
        "lower": 450.0,
        "upper": 750.0,
        "choices": []
      },
      { "name": "pressure", "kind": "continuous", "lower": 0.5, "upper": 3.5, "choices": [] },
      { "name": "synthesis_time", "kind": "continuous", "lower": 1.0, "upper": 5.0, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 16,
    "batch_size": 4,
    "max_failures": 4
  },
  "simulator": "fake",
  "seed": 88,
  "tags": ["exploration", "batch-comparison", "optimizer-observation"],
  "metadata": {
    "operator_prompt": "Watch how the planner and critic evolve over several batches and summarize the search direction shifts.",
    "analysis_focus": "exploration versus exploitation"
  }
}
