{
  "name": "cautious-feasible-search",
  "description": "Feasibility-oriented search with tighter constraints and smaller batches.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_conductivity",
      "metric_key": "conductivity",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [
    {
      "name": "cost_threshold",
      "metric_key": "cost",
      "operator": "lt",
      "threshold": 48.0
    },
    {
      "name": "stability_threshold",
      "metric_key": "stability",
      "operator": "gt",
      "threshold": 0.78
    }
  ],
  "search_space": {
    "dimensions": [
      { "name": "dopant_ratio", "kind": "continuous", "lower": 0.1, "upper": 0.42, "choices": [] },
      {
        "name": "anneal_temperature",
        "kind": "continuous",
        "lower": 500.0,
        "upper": 710.0,
        "choices": []
      },
      { "name": "pressure", "kind": "continuous", "lower": 1.0, "upper": 3.0, "choices": [] },
      { "name": "synthesis_time", "kind": "continuous", "lower": 1.5, "upper": 4.0, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 10,
    "batch_size": 1,
    "max_failures": 2
  },
  "simulator": "fake",
  "seed": 7,
  "tags": ["risk-aware", "feasibility", "single-step"],
  "metadata": {
    "operator_prompt": "Prefer feasible improvement over aggressive exploration.",
    "analysis_focus": "constraint margin"
  }
}
