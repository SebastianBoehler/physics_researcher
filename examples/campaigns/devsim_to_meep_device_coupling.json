{
  "name": "devsim-to-meep-device-coupling",
  "description": "Device-to-photonics coupling workflow for electro-optic screening.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_transmission_peak",
      "metric_key": "transmission_peak",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "bias", "kind": "continuous", "lower": 0.05, "upper": 0.8, "choices": [] },
      { "name": "fcen", "kind": "continuous", "lower": 0.1, "upper": 0.25, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 4,
    "batch_size": 1,
    "max_failures": 2
  },
  "simulator": "devsim",
  "workflow": {
    "name": "devsim-to-meep",
    "stages": [
      {
        "name": "device",
        "simulator": "devsim",
        "task": {
          "name": "devsim_dc",
          "simulator": "devsim",
          "parameters": { "device_name": "pn_diode", "bias": 0.2 },
          "units": { "bias": "V" },
          "expected_outputs": ["devsim_results.json", "stdout.log", "stderr.log"],
          "metadata": {}
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      },
      {
        "name": "photonics",
        "simulator": "meep",
        "task": {
          "name": "meep_flux_scan",
          "simulator": "meep",
          "parameters": { "resolution": 20, "fcen": 0.15, "df": 0.1, "nfreq": 25, "until": 50 },
          "units": {},
          "expected_outputs": ["meep_results.json", "stdout.log", "stderr.log"],
          "metadata": {}
        },
        "depends_on": ["device"],
        "mapping_id": "devsim_to_meep",
        "metadata": {}
      }
    ],
    "metadata": {
      "story": "Use device-state outputs to inform a downstream photonic stage."
    }
  },
  "seed": 21,
  "tags": ["workflow", "devsim", "meep", "device-coupling"],
  "metadata": {
    "operator_prompt": "Couple device-state outputs into a MEEP stage and report every transferred parameter.",
    "analysis_focus": "electro-optic coupling traceability"
  }
}
