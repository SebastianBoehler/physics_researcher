{
  "name": "baseline-conductivity-search",
  "description": "Baseline fake-simulator search for feasible high-conductivity candidates.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_conductivity",
      "metric_key": "conductivity",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [
    {
      "name": "cost_threshold",
      "metric_key": "cost",
      "operator": "lt",
      "threshold": 55.0
    },
    {
      "name": "stability_threshold",
      "metric_key": "stability",
      "operator": "gt",
      "threshold": 0.7
    }
  ],
  "search_space": {
    "dimensions": [
      { "name": "dopant_ratio", "kind": "continuous", "lower": 0.05, "upper": 0.5, "choices": [] },
      {
        "name": "anneal_temperature",
        "kind": "continuous",
        "lower": 450.0,
        "upper": 750.0,
        "choices": []
      },
      { "name": "pressure", "kind": "continuous", "lower": 0.5, "upper": 3.5, "choices": [] },
      { "name": "synthesis_time", "kind": "continuous", "lower": 1.0, "upper": 5.0, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 12,
    "batch_size": 2,
    "max_failures": 3
  },
  "simulator": "fake",
  "seed": 42,
  "tags": ["baseline", "conductivity", "materials-discovery"],
  "metadata": {
    "operator_prompt": "Run a baseline conductivity maximization campaign and explain each batch choice.",
    "analysis_focus": "feasible best-so-far"
  }
}
