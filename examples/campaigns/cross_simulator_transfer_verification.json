{
  "name": "cross-simulator-transfer-verification",
  "description": "Verification-focused workflow for transfer correctness across simulator stages.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_transmission_peak",
      "metric_key": "transmission_peak",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "ecutwfc", "kind": "continuous", "lower": 20.0, "upper": 80.0, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 2,
    "batch_size": 1,
    "max_failures": 1
  },
  "simulator": "quantum_espresso",
  "workflow": {
    "name": "verification-qe-to-meep",
    "stages": [
      {
        "name": "qe",
        "simulator": "quantum_espresso",
        "task": {
          "name": "qe_scf",
          "simulator": "quantum_espresso",
          "parameters": { "ecutwfc": 30.0, "conv_thr": 1e-06 },
          "units": { "ecutwfc": "Ry" },
          "expected_outputs": ["qe.in", "stdout.log", "stderr.log"],
          "metadata": {}
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      },
      {
        "name": "meep",
        "simulator": "meep",
        "task": {
          "name": "meep_flux_scan",
          "simulator": "meep",
          "parameters": { "resolution": 20, "fcen": 0.15, "df": 0.1, "nfreq": 25, "until": 50 },
          "units": {},
          "expected_outputs": ["meep_results.json", "stdout.log", "stderr.log"],
          "metadata": {
            "verification_checks": [
              "parameter_echo",
              "derived_property_tolerance",
              "artifact_completeness",
              "provenance_capture"
            ]
          }
        },
        "depends_on": ["qe"],
        "mapping_id": "quantum_espresso_to_meep",
        "metadata": {}
      }
    ],
    "metadata": {
      "story": "Prove that stage mappings, units, and artifacts are preserved across the boundary."
    }
  },
  "seed": 5,
  "tags": ["verification", "workflow", "cross-simulator"],
  "metadata": {
    "operator_prompt": "Use this workflow to verify transfer correctness and provenance across simulator stages.",
    "analysis_focus": "transfer validation and artifact completeness"
  }
}
