AUTOLAB_ENV=local
AUTOLAB_API_HOST=0.0.0.0
AUTOLAB_API_PORT=8000
AUTOLAB_ADMIN_TOKEN=dev-token
AUTOLAB_DATABASE_URL=postgresql+psycopg://autolab:autolab@postgres:5432/autolab
AUTOLAB_REDIS_URL=redis://redis:6379/0
AUTOLAB_MLFLOW_TRACKING_URI=http://mlflow:5000
AUTOLAB_OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
AUTOLAB_RAY_ADDRESS=auto
AUTOLAB_ARTIFACT_ROOT=/data/artifacts
AUTOLAB_DEFAULT_SIMULATOR=fake
AUTOLAB_EXECUTION_MODE=async
