{
  "name": "thermoelectric-high-pf-screen",
  "description": "Benchmark task with a high-power-factor prior over the thermoelectric search space.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_power_factor",
      "metric_key": "power_factor",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [
    {
      "name": "minimum_conductivity",
      "metric_key": "electrical_conductivity",
      "operator": "gte",
      "threshold": 60000.0
    }
  ],
  "search_space": {
    "dimensions": [
      { "name": "dopant_fraction", "kind": "continuous", "lower": 0.18, "upper": 0.22, "choices": [] },
      { "name": "sinter_temperature_c", "kind": "continuous", "lower": 760.0, "upper": 820.0, "choices": [] },
      { "name": "anneal_hours", "kind": "continuous", "lower": 7.0, "upper": 10.0, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 6,
    "batch_size": 1,
    "max_failures": 1
  },
  "simulator": "manual_protocol",
  "workflow": {
    "name": "thermoelectric-high-pf-benchmark",
    "stages": [
      {
        "name": "fabrication_protocol",
        "simulator": "manual_protocol",
        "task": {
          "name": "manual_protocol",
          "simulator": "manual_protocol",
          "parameters": {
            "material_family": "thermoelectric",
            "sample_id_template": "te-highpf-{candidate_id_short}",
            "process_temperature_c": 790.0,
            "dwell_time_hours": 8.0,
            "atmosphere": "argon",
            "required_materials": ["Bi2Te3 precursor", "Sb2Te3 precursor", "press die"]
          },
          "units": {
            "process_temperature_c": "celsius",
            "dwell_time_hours": "hour"
          },
          "expected_outputs": ["protocol.md", "recipe.json", "handoff.json", "stdout.log", "stderr.log"],
          "metadata": {
            "benchmark_role": "high_pf_protocol"
          }
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      },
      {
        "name": "measurement",
        "simulator": "csv_measurement",
        "task": {
          "name": "csv_measurement",
          "simulator": "csv_measurement",
          "parameters": {
            "required_columns": [
              "sample_id",
              "replicate_id",
              "temperature_k",
              "delta_t_k",
              "voltage_v",
              "current_a",
              "resistance_ohm",
              "length_m",
              "area_m2"
            ],
            "min_replicates": 3,
            "auto_generate_from_candidate": true
          },
          "units": {},
          "expected_outputs": ["measurement.csv", "measurement_ingest.json", "stdout.log", "stderr.log"],
          "metadata": {
            "benchmark_role": "measurement_feedback"
          }
        },
        "depends_on": ["fabrication_protocol"],
        "mapping_id": null,
        "metadata": {}
      }
    ],
    "metadata": {
      "benchmark_family": "thermoelectric_measurement",
      "benchmark_scope": "high_pf"
    }
  },
  "seed": 53,
  "tags": ["benchmark", "thermoelectric", "measurement", "high-pf"],
  "metadata": {
    "benchmark_id": "te-high-pf",
    "operator_prompt": "Use this benchmark to measure performance when the thermoelectric search is already restricted to a high-power-factor region.",
    "analysis_focus": "high-power-factor prior with full artifact coverage"
  }
}
