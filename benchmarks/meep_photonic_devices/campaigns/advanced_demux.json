          "units": {
            "sx": "um",
            "sy": "um",
            "block_x": "um",
            "block_y": "um",
            "block_center_x": "um",
            "block_center_y": "um",
            "block2_x": "um",
            "block2_y": "um",
            "block2_center_x": "um",
            "block2_center_y": "um",
            "block3_x": "um",
            "block3_y": "um",
            "block3_center_x": "um",
            "block3_center_y": "um",
            "arm_separation": "um",
            "output_width": "um"
          },
          "expected_outputs": ["meep_results.json", "stdout.log", "stderr.log"]
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      }
    ],
    "metadata": {
      "benchmark_family": "meep_photonic_devices_advanced",
      "difficulty": "high"
    }
  },
  "seed": 503,
  "tags": ["benchmark", "meep", "photonics", "demux", "advanced"],
  "metadata": {
    "benchmark_id": "meep-demux-advanced",
    "analysis_focus": "coarse-to-fine demux search with an extra scatterer block",
    "optimizer": {
      "algorithm": "coarse_to_fine_bayesian",
      "candidate_pool_size": 64,
      "coarse_observation_count": 6,
      "top_candidate_count": 3,
      "minimum_window_fraction": 0.22,
      "padding_fraction": 0.08
    }
  }
