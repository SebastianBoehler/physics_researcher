{
  "name": "benchmark-meep-demux-advanced",
  "description": "Higher-budget demux benchmark with coarse-to-fine Bayesian search and a third optional scatterer block.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_literature_shaped_device_score",
      "metric_key": "device_score",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "block_x", "kind": "continuous", "lower": 3.4, "upper": 4.9, "choices": [] },
      { "name": "block_y", "kind": "continuous", "lower": 4.2, "upper": 5.6, "choices": [] },
      { "name": "refractive_index", "kind": "continuous", "lower": 3.3, "upper": 3.95, "choices": [] },
      { "name": "arm_separation", "kind": "continuous", "lower": 2.4, "upper": 3.3, "choices": [] },
      { "name": "output_width", "kind": "continuous", "lower": 0.95, "upper": 1.3, "choices": [] },
      { "name": "block_center_x", "kind": "continuous", "lower": -0.6, "upper": 1.0, "choices": [] },
      { "name": "block_center_y", "kind": "continuous", "lower": -1.6, "upper": 1.6, "choices": [] },
      { "name": "block2_x", "kind": "continuous", "lower": 0.0, "upper": 2.9, "choices": [] },
      { "name": "block2_y", "kind": "continuous", "lower": 0.0, "upper": 2.9, "choices": [] },
      { "name": "block2_center_x", "kind": "continuous", "lower": -1.4, "upper": 1.6, "choices": [] },
      { "name": "block2_center_y", "kind": "continuous", "lower": -2.8, "upper": 2.8, "choices": [] },
      { "name": "block3_x", "kind": "continuous", "lower": 0.0, "upper": 1.9, "choices": [] },
      { "name": "block3_y", "kind": "continuous", "lower": 0.0, "upper": 1.9, "choices": [] },
      { "name": "block3_center_x", "kind": "continuous", "lower": -1.9, "upper": 1.9, "choices": [] },
      { "name": "block3_center_y", "kind": "continuous", "lower": -3.0, "upper": 3.0, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 18,
    "batch_size": 1,
    "max_failures": 4
  },
  "simulator": "meep",
  "workflow": {
    "name": "benchmark-meep-demux-advanced",
    "stages": [
      {
        "name": "meep",
        "simulator": "meep",
        "task": {
          "name": "meep_flux_scan",
          "simulator": "meep",
          "parameters": {
            "device_kind": "demux",
            "sx": 20.0,
            "sy": 10.0,
            "block_x": 4.2,
            "block_y": 4.9,
            "block_center_x": 0.3,
            "block_center_y": 0.0,
            "block2_x": 1.4,
            "block2_y": 1.2,
            "block2_center_x": -0.2,
            "block2_center_y": 1.0,
            "block3_x": 0.0,
            "block3_y": 0.0,
            "block3_center_x": 0.0,
            "block3_center_y": 0.0,
            "refractive_index": 3.7,
            "input_width": 1.0,
            "output_width": 1.12,
            "arm_separation": 2.8,
            "input_length": 5.0,
            "output_length": 5.0,
            "route_low_port": "upper",
            "route_high_port": "lower",
            "resolution": 28,
            "dpml": 1.0,
            "fcen": 0.16,
            "df": 0.12,
            "nfreq": 73,
            "until": 120
