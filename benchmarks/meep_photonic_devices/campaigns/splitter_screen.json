{
  "name": "benchmark-meep-splitter",
  "description": "Fast benchmark for two-port photonic splitter optimization.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_device_score",
      "metric_key": "device_score",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "block_x", "kind": "continuous", "lower": 2.0, "upper": 5.0, "choices": [] },
      { "name": "block_y", "kind": "continuous", "lower": 3.0, "upper": 6.5, "choices": [] },
      { "name": "refractive_index", "kind": "continuous", "lower": 2.4, "upper": 3.8, "choices": [] },
      { "name": "arm_separation", "kind": "continuous", "lower": 2.2, "upper": 4.2, "choices": [] },
      { "name": "output_width", "kind": "continuous", "lower": 0.6, "upper": 1.4, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 4,
    "batch_size": 1,
    "max_failures": 2
  },
  "simulator": "meep",
  "workflow": {
    "name": "benchmark-meep-splitter",
    "stages": [
      {
        "name": "meep",
        "simulator": "meep",
        "task": {
          "name": "meep_flux_scan",
          "simulator": "meep",
          "parameters": {
            "device_kind": "splitter",
            "sx": 20.0,
            "sy": 10.0,
            "block_x": 3.0,
            "block_y": 4.8,
            "refractive_index": 3.2,
            "input_width": 1.0,
            "output_width": 1.0,
            "arm_separation": 3.0,
            "input_length": 5.0,
            "output_length": 5.0,
            "resolution": 18,
            "dpml": 1.0,
            "fcen": 0.15,
            "df": 0.1,
            "nfreq": 25,
            "until": 60
          },
          "units": {
            "sx": "um",
            "sy": "um",
            "block_x": "um",
            "block_y": "um",
            "arm_separation": "um",
            "output_width": "um"
          },
          "expected_outputs": ["meep_results.json", "stdout.log", "stderr.log"]
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      }
    ],
    "metadata": {
      "benchmark_family": "meep_photonic_devices",
      "difficulty": "medium"
    }
  },
  "seed": 302,
  "tags": ["benchmark", "meep", "photonics", "splitter"],
  "metadata": {
    "benchmark_id": "meep-splitter",
    "analysis_focus": "throughput versus split balance"
  }
}
