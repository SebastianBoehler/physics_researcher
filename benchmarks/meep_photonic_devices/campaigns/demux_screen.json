{
  "name": "benchmark-meep-demux",
  "description": "Fast benchmark for two-port spectral routing in a photonic demultiplexer layout.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_device_score",
      "metric_key": "device_score",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "block_x", "kind": "continuous", "lower": 2.2, "upper": 5.4, "choices": [] },
      { "name": "block_y", "kind": "continuous", "lower": 3.5, "upper": 7.0, "choices": [] },
      {
        "name": "refractive_index",
        "kind": "continuous",
        "lower": 2.4,
        "upper": 4.0,
        "choices": []
      },
      { "name": "arm_separation", "kind": "continuous", "lower": 2.4, "upper": 4.6, "choices": [] },
      { "name": "output_width", "kind": "continuous", "lower": 0.6, "upper": 1.3, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 4,
    "batch_size": 1,
    "max_failures": 2
  },
  "simulator": "meep",
  "workflow": {
    "name": "benchmark-meep-demux",
    "stages": [
      {
        "name": "meep",
        "simulator": "meep",
        "task": {
          "name": "meep_flux_scan",
          "simulator": "meep",
          "parameters": {
            "device_kind": "demux",
            "sx": 20.0,
            "sy": 10.0,
            "block_x": 3.4,
            "block_y": 5.0,
            "refractive_index": 3.3,
            "input_width": 1.0,
            "output_width": 0.9,
            "arm_separation": 3.2,
            "input_length": 5.0,
            "output_length": 5.0,
            "route_low_port": "upper",
            "route_high_port": "lower",
            "resolution": 18,
            "dpml": 1.0,
            "fcen": 0.16,
            "df": 0.12,
            "nfreq": 31,
            "until": 70
          },
          "units": {
            "sx": "um",
            "sy": "um",
            "block_x": "um",
            "block_y": "um",
            "arm_separation": "um",
            "output_width": "um"
          },
          "expected_outputs": ["meep_results.json", "stdout.log", "stderr.log"]
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      }
    ],
    "metadata": {
      "benchmark_family": "meep_photonic_devices",
      "difficulty": "medium"
    }
  },
  "seed": 303,
  "tags": ["benchmark", "meep", "photonics", "demux"],
  "metadata": {
    "benchmark_id": "meep-demux",
