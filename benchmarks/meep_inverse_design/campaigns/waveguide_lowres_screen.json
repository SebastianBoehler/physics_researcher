          "units": {
            "sx": "um",
            "sy": "um",
            "block_x": "um",
            "block_y": "um"
          },
          "expected_outputs": ["meep_results.json", "stdout.log", "stderr.log"],
          "metadata": {
            "benchmark_role": "fast_screen"
          }
        },
        "depends_on": [],
        "mapping_id": null,
        "metadata": {}
      }
    ],
    "metadata": {
      "benchmark_family": "meep_inverse_design",
      "difficulty": "low"
    }
  },
  "seed": 101,
  "tags": ["benchmark", "meep", "inverse-design", "lowres"],
  "metadata": {
    "benchmark_id": "meep-lowres",
    "operator_prompt": "Use this low-resolution MEEP benchmark to test rapid optimization loops and artifact coverage.",
    "analysis_focus": "fast transmission optimization"
  }
