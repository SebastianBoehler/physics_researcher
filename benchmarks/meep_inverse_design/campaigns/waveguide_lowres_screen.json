{
  "name": "benchmark-meep-waveguide-lowres",
  "description": "Low-resolution standalone MEEP screen for fast benchmarking iterations.",
  "mode": "materials_discovery",
  "objectives": [
    {
      "name": "maximize_transmission_peak",
      "metric_key": "transmission_peak",
      "direction": "maximize",
      "weight": 1.0
    }
  ],
  "constraints": [],
  "search_space": {
    "dimensions": [
      { "name": "block_x", "kind": "continuous", "lower": 0.5, "upper": 1.6, "choices": [] },
      { "name": "block_y", "kind": "continuous", "lower": 2.0, "upper": 5.0, "choices": [] },
      { "name": "refractive_index", "kind": "continuous", "lower": 1.6, "upper": 3.8, "choices": [] }
    ]
  },
  "budget": {
    "max_runs": 4,
    "batch_size": 1,
    "max_failures": 2
  },
  "simulator": "meep",
  "workflow": {
    "name": "benchmark-meep-waveguide-lowres",
    "stages": [
      {
        "name": "meep",
        "simulator": "meep",
        "task": {
          "name": "meep_flux_scan",
          "simulator": "meep",
          "parameters": {
            "sx": 16.0,
            "sy": 8.0,
            "block_x": 1.0,
            "block_y": 4.0,
            "refractive_index": 3.2,
            "resolution": 12,
            "dpml": 1.0,
            "fcen": 0.15,
            "df": 0.1,
            "nfreq": 25,
            "until": 40
